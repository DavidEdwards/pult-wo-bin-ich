# Pult account (used for token refresh)
PULT_LOGIN_EMAIL=
# Bearer token for api.pult.com (set manually or via auth helper)
AUTH_TOKEN=

# Comma-separated "First Last" pairs to locate on the floor map (empty = fall back to built-in defaults)
TARGET_USERS=

# Slack — bot posts to this channel
SLACK_BOT_TOKEN=
SLACK_CHANNEL=
# Slack user ID for token-expiry DMs (e.g. U123ABC)
SLACK_DM_USER_ID=

# If true, skip sending to Slack (still builds layout)
DRY_RUN=false

# Local auth helper (auth-server.js)
AUTH_SERVER_PORT=8787
AUTH_SERVER_BIND_HOST=0.0.0.0
AUTH_SERVER_BASE_URL=http://localhost:8787
AUTH_SERVER_AUTOSTART=true
TOKEN_REFRESH_WAIT_MS=1800000
TOKEN_REFRESH_POLL_MS=2000
